{
  "$comment": "Single source of stack-specific config. Filled by /init-project. Commands/hooks/skills read from here instead of hard-coding npm/biome/etc. '__FILL__' = not configured yet.",
  "project": {
    "name": "EC-VoucherHub",
    "description": "Hệ thống thương mại điện tử bán voucher giảm giá trực tuyến (monorepo: Express API + React/Vite SPA + shared).",
    "language": "TypeScript",
    "framework": "Express + React (Vite), npm workspaces monorepo"
  },
  "commands": {
    "install": "npm ci",
    "build": "npm run build",
    "test": "npm test",
    "test_watch": "npx vitest --watch",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "ci": "npm run typecheck --workspaces --if-present && npm run build && npm test",
    "dev": "npm run dev",
    "start": "npm run start --workspace=backend",
    "e2e": "npm run test:e2e"
  },
  "runtime": {
    "port": "4000",
    "health_url": "http://localhost:4000/health",
    "base_url": "http://localhost:4000"
  },
  "capabilities": {
    "has_database": true,
    "has_web_ui": true,
    "has_e2e": true,
    "has_http_api": true
  },
  "paths": {
    "source_dir": "backend/src",
    "test_dir": "backend/src",
    "e2e_dir": "e2e",
    "ui_files": [
      "frontend/src/**"
    ],
    "db_dir": "backend/prisma"
  },
  "format_extensions": [".ts", ".tsx"],
  "secret_file_globs": [".env", "*.pem", "id_rsa", "credentials.json", "*.p12", "*.key"]
}
