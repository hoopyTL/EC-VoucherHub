{
  "name": "ec-voucherhub",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "ec-voucherhub",
      "version": "1.0.0",
      "license": "MIT",
      "workspaces": [
        "shared",
        "backend",
        "frontend"
      ],
      "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
      }
    },
    "backend": {
      "name": "@voucher/backend",
      "version": "1.0.0",
      "dependencies": {
        "@voucher/shared": "*"
      },
      "devDependencies": {
        "typescript": "^5.7.0"
      }
    },
    "client": {
      "name": "@voucher/client",
      "version": "1.0.0",
      "extraneous": true,
      "dependencies": {
        "@voucher/shared": "*"
      },
      "devDependencies": {
        "typescript": "^5.7.0"
      }
    },
    "frontend": {
      "name": "@voucher/frontend",
      "version": "1.0.0",
      "dependencies": {
        "@voucher/shared": "*"
      },
      "devDependencies": {
        "typescript": "^5.7.0"
      }
    },
    "node_modules/@voucher/backend": {
      "resolved": "backend",
      "link": true
    },
    "node_modules/@voucher/frontend": {
      "resolved": "frontend",
      "link": true
    },
    "node_modules/@voucher/shared": {
      "resolved": "shared",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "server": {
      "name": "@voucher/server",
      "version": "1.0.0",
      "extraneous": true,
      "dependencies": {
        "@voucher/shared": "*"
      },
      "devDependencies": {
        "typescript": "^5.7.0"
      }
    },
    "shared": {
      "name": "@voucher/shared",
      "version": "1.0.0",
      "devDependencies": {
        "typescript": "^5.7.0"
      }
    }
  }
}
