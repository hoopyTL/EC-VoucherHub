# ============================================
# EC-VoucherHub — Backend Environment
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env — it is gitignored.
# In production these are injected by the host's secret manager, not a file.

# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voucherhub

# ---- JWT ----
# In production JWT_SECRET must be long + random (not this placeholder) — config validation enforces it.
JWT_SECRET=dev-only-secret-change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=30d

# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
